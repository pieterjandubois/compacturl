# Vercel Ignore File
# Files and directories to exclude from Vercel deployment

# Local environment files
.env
.env.local
.env.*.local

# Development files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# Documentation (optional - remove if you want docs deployed)
*.md
!README.md

# Local development
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Scripts (optional - remove if needed)
scripts/

# Docker
docker-compose.yml
Dockerfile
.dockerignore

# Redis setup files (not needed in Vercel)
REDIS_SETUP.md
REDIS_DOCKER_SETUP.md

# Local setup guides
LOCAL_SETUP.md
QUICKSTART.md
QUICKSTART_WINDOWS.md
SETUP_CHECKLIST.md
GETTING_STARTED_SUMMARY.md
