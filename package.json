{
  "name": "compact-url",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "verify-setup": "node verify-setup.js",
    "setup:db": "node scripts/create-database.js",
    "setup:db-simple": "node scripts/create-database-simple.js",
    "redis:start": "docker-compose up -d",
    "redis:stop": "docker-compose down",
    "redis:logs": "docker logs compacturl-redis",
    "redis:test": "docker exec -it compacturl-redis redis-cli ping",
    "redis:cli": "docker exec -it compacturl-redis redis-cli"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.20.0",
    "bcrypt": "^5.1.1",
    "ioredis": "^5.4.1",
    "next": "^14.2.0",
    "next-auth": "^4.24.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "fast-check": "^3.22.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "pg": "^8.19.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  }
}
